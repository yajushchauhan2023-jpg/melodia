generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum Plan {
  free_trial
  pro
  elite
}

model User {
  id                   String             @id
  email                String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  subscriptionStatus   SubscriptionStatus @default(expired)
  trialEndsAt          DateTime?
  currentPlan          Plan               @default(free_trial)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  emailLogs            EmailLog[]

  // Lesson plan profile, collected once at signup onboarding
  instrument           String?
  level                String?
  goal                 String?
  weeklyTime           String?
  lessonIndex          Int                @default(0)
  lessonPlanUpdatedAt  DateTime?
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}
